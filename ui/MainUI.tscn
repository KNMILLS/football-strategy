[node name="HelpText" type="RichTextLabel" parent="HelpOverlay"]
layout_mode = 2
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 24.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = -24.0
bbcode_enabled = true
text = "[b]Help[/b]
- 1..6 choose offense.
- Q/W/E/R choose defense in Hot Seat.
- First downs use line-to-gain markers; penalties replay and can award first by yardage.
- TD = 6 + Try (XP or 2); FG = 3.
- Kickoffs after Try: TB → B30 (0s), landing-zone returns ~B20–B30, OOB → B40.
- Onside available only when trailing.
- Punts can result in touchback to the 20.
- Fumbles 50% recovery.
- H toggles this overlay.
- Quick Play: Enter. HUD: F1."

